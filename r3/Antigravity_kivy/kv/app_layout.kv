#:kivy 2.0.0

# Set default font for all widgets that have text
<Label>:
    font_name: 'Kanit'
<Button>:
    font_name: 'Kanit'
<TextInput>:
    font_name: 'Kanit'
<SpinnerOption>:
    font_name: 'Kanit'

<BoxLayout>:
    canvas.after:
        Color:
            rgba: 1, 0, 0, 1  # สีแดง (Red, Green, Blue, Alpha)
        Line:
            rectangle: self.x, self.y, self.width, self.height
            width: 1          # ความหนาของเส้น


<LoginScreen>:
    name: 'login'
    BoxLayout:
        orientation: 'vertical'
        padding: root.width * 0.1, root.height * 0.1
        spacing: root.height * 0.02
        
        Label:
            text: 'ระบบจัดการสินค้าคงคลังด้วย RFID'
            font_size: self.height * 0.4
            size_hint_y: 0.2
            
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 0.1
            spacing: 10
            size_hint_x: 0.6
            pos_hint: {'center_x': 0.5}
            
            ToggleButton:
                id: btn_mode_password
                text: 'User/Password'
                font_size: self.height * 0.4
                state: 'down'
                group: 'login_mode'
                on_release: root.set_login_mode('Password')
                
            ToggleButton:
                id: btn_mode_apikey
                text: 'API Key'
                font_size: self.height * 0.4
                group: 'login_mode'
                on_release: root.set_login_mode('API Key')
                
        BoxLayout:
            orientation: 'vertical'
            spacing: 10
            size_hint_y: 0.35           
            size_hint_x: 0.8
            pos_hint: {'center_x': 0.5}            

            BoxLayout:
                id: username_container
                orientation: 'vertical'
                size_hint_y: 0.5
                opacity: 1
                disabled: False
                
                Label:
                    text: 'ชื่อผู้ใช้ (Username)'
                    size_hint_y: 0.4
                    font_size: self.height * 0.6
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                    
                TextInput:
                    id: username_input
                    multiline: False
                    size_hint_y: 0.6
                    font_size: self.height * 0.5
                    size_hint_x: 0.6
                    pos_hint: {'center_x': 0.5}
                    halign: 'center'
                    
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: 0.5
                
                Label:
                    id: credential_label
                    text: 'รหัสผ่าน (Password)'
                    size_hint_y: 0.4
                    font_size: self.height * 0.6
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                                        
                TextInput:
                    id: credential_input
                    multiline: False
                    password: True
                    size_hint_y: 0.6
                    font_size: self.height * 0.5
                    size_hint_x: 0.6
                    pos_hint: {'center_x': 0.5}
                    halign: 'center'
                                    
        Button:
            text: 'เข้าสู่ระบบ (Login)'
            size_hint_y: 0.15
            font_size: self.height * 0.4
            background_color: 0.2, 0.6, 1, 1
            on_release: root.do_login()
            size_hint_x: 0.4
            pos_hint: {'center_x': 0.5}

        Label:
            id: login_message
            text: '---------------------------------------------------------------'
            color: 1, 0, 0, 1
            size_hint_y: 0.2
            font_size: self.height * 0.3
                  

<MainTabScreen>:
    name: 'main_tabs'
    BoxLayout:
        orientation: 'vertical'
        
        BoxLayout:
            size_hint_y: 0.08
            padding: [10, 5]
            canvas.before:
                Color:
                    rgba: 0.2, 0.2, 0.2, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Label:
                id: current_user_label
                text: 'ผู้ใช้งาน: '
                text_size: self.size
                halign: 'left'
                valign: 'middle'
                font_size: self.height * 0.5
                

                
        TabbedPanel:
            do_default_tab: False
            tab_pos: 'top_mid'
            tab_width: self.width / 4
        
            TabbedPanelItem:
                text: '1. นำเข้า RFID'
                ImportTagTab:
                    id: import_tab
                    
            TabbedPanelItem:
                text: '2. จัดการสินค้า'
                InventoryTab:
                    id: inventory_tab
                    
            TabbedPanelItem:
                text: '3. กำหนด Location'
                LocationTab:
                    id: location_tab
                    
            TabbedPanelItem:
                text: '4. ตรวจสอบสินค้า'
                InspectionTab:
                    id: inspection_tab

<ImportTagTab>:
    orientation: 'vertical'
    padding: 20
    spacing: 10
    
    Label:
        text: 'สแกน RFID Tag เพื่อนำเข้าระบบ'
        font_size: self.height * 0.6
        size_hint_y: 0.1
        
    BoxLayout:
        size_hint_y: 0.1
        spacing: 10
        Button:
            id: toggle_scan_btn
            text: 'เริ่มอ่าน (Start Scan)'
            font_size: self.height * 0.4
            size_hint_x: 0.3
            background_color: 0.2, 0.6, 1, 1
            on_release: app.screens['main_tabs'].ids.import_tab.toggle_scanning()
        TextInput:
            id: rfid_scan_input
            multiline: False
            hint_text: 'กดเริ่มอ่านเพื่อสแกน...'
            font_size: self.height * 0.4
            size_hint_x: 0.7
            disabled: True
            on_text_validate: app.screens['main_tabs'].ids.import_tab.add_scanned_tag(self.text)
            
    Label:
        id: scan_count_label
        text: 'อ่านแล้ว: 0 รหัส'
        size_hint_y: 0.1
        font_size: self.height * 0.5
        color: 0.2, 0.8, 1, 1
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        
    ScrollView:
        size_hint_y: 0.6
        BoxLayout:
            id: scanned_tags_list
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            
    BoxLayout:
        size_hint_y: 0.1
        spacing: 20
        Button:
            text: 'ล้างข้อมูล (Clear)'
            font_size: self.height * 0.4
            background_color: 1, 0.3, 0.3, 1
            on_release: app.screens['main_tabs'].ids.import_tab.clear_tags()
        Button:
            text: 'บันทึกเข้าระบบ (Import)'
            font_size: self.height * 0.4
            background_color: 0.2, 0.8, 0.2, 1
            on_release: app.screens['main_tabs'].ids.import_tab.submit_tags()

<InventoryTab>:
    orientation: 'vertical'
    padding: 20
    spacing: 10
    
    Label:
        text: 'ลงทะเบียน / จัดการสินค้า'
        font_size: self.height * 0.6
        size_hint_y: 0.1
        
    GridLayout:
        cols: 2
        spacing: 10
        size_hint_y: 0.6
        
        Label:
            text: 'เลือก RFID Code (ที่ยังไม่ใช้งาน):'
            text_size: self.size
            halign: 'right'
            valign: 'middle'
            font_size: self.height * 0.3
        Spinner:
            id: rfid_spinner
            text: '--- เลือก RFID ---'
            font_size: self.height * 0.3
            values: []
            on_text: root.on_rfid_select(self.text)
            
        Label:
            text: 'ชื่อสินค้า:'
            text_size: self.size
            halign: 'right'
            valign: 'middle'
            font_size: self.height * 0.3
        TextInput:
            id: inv_name_input
            multiline: False
            font_size: self.height * 0.3
            
        Label:
            text: 'รายละเอียดสินค้า:'
            text_size: self.size
            halign: 'right'
            valign: 'top'
            font_size: self.height * 0.3
        TextInput:
            id: inv_detail_input
            multiline: True
            font_size: self.height * 0.3

# ----------------------------------------------------
    # 2. ส่วนที่เพิ่มใหม่ สำหรับอัปโหลดและแสดงรูปภาพ
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.4
        spacing: 10
        
        # ปุ่มสำหรับเปิด Popup ค้นหารูปภาพในเครื่อง
        Button:
            text: 'เลือกรูปภาพประกอบ\n(คลิกที่นี่)'
            font_name: 'Kanit'
            halign: 'center'
            size_hint_x: 0.3
            background_color: 0.2, 0.6, 1, 1
            on_release: root.choose_image()
        
        # Widget สำหรับแสดงรูปภาพ (ใช้ AsyncImage เพื่อไม่ให้ UI ค้างตอนโหลดรูปจากเน็ต)
        AsyncImage:
            id: inv_image
            source: ''
            allow_stretch: True
            keep_ratio: True
            size_hint_x: 0.7
    # ----------------------------------------------------

            
    Button:
        text: 'ดึงข้อมูล RFID ใหม่ (Refresh)'
        size_hint_y: 0.1
        font_size: self.height * 0.4
        on_release: app.screens['main_tabs'].ids.inventory_tab.refresh_rfid_list()
        
    Button:
        text: 'บันทึกข้อมูลสินค้า'
        size_hint_y: 0.15
        font_size: self.height * 0.4
        background_color: 0.2, 0.6, 1, 1
        on_release: app.screens['main_tabs'].ids.inventory_tab.submit_inventory()

<LocationTab>:
    orientation: 'vertical'
    padding: 20
    spacing: 10
    
    Label:
        text: 'กำหนดสถานที่ (Location)'
        font_size: self.height * 0.6
        size_hint_y: 0.1
        
    GridLayout:
        cols: 2
        spacing: 10
        size_hint_y: 0.6
        
        Label:
            text: 'เลือก RFID Code (ที่ยังไม่ใช้งาน):'
            text_size: self.size
            halign: 'right'
            valign: 'middle'
            font_size: self.height * 0.3
        Spinner:
            id: loc_rfid_spinner
            text: '--- เลือก RFID ---'
            font_size: self.height * 0.3
            
        Label:
            text: 'ชื่อ Location:'
            text_size: self.size
            halign: 'right'
            valign: 'middle'
            font_size: self.height * 0.3
        TextInput:
            id: loc_name_input
            multiline: False
            font_size: self.height * 0.3
            
        Label:
            text: 'รายละเอียด:'
            text_size: self.size
            halign: 'right'
            valign: 'top'
            font_size: self.height * 0.3
        TextInput:
            id: loc_detail_input
            multiline: True
            font_size: self.height * 0.3
            
    Button:
        text: 'ดึงข้อมูล RFID ใหม่ (Refresh)'
        size_hint_y: 0.1
        font_size: self.height * 0.4
        on_release: app.screens['main_tabs'].ids.location_tab.refresh_rfid_list()
        
    Button:
        text: 'บันทึกข้อมูล Location'
        size_hint_y: 0.15
        font_size: self.height * 0.4
        background_color: 0.2, 0.6, 1, 1
        on_release: app.screens['main_tabs'].ids.location_tab.submit_location()

<InspectionTab>:
    orientation: 'vertical'
    padding: 20
    spacing: 10
    
    Label:
        text: 'ตรวจสอบสินค้า (Inspection)'
        font_size: self.height * 0.6
        size_hint_y: 0.1
        
    BoxLayout:
        size_hint_y: 0.1
        spacing: 10
        Label:
            text: 'สแกน Location RFID:'
            font_size: self.height * 0.4
            size_hint_x: 0.3
        TextInput:
            id: inspect_loc_input
            multiline: False
            hint_text: 'สแกนป้ายสถานที่...'
            font_size: self.height * 0.4
            on_text_validate: app.screens['main_tabs'].ids.inspection_tab.on_location_scanned(self.text)
            
    Label:
        id: current_location_label
        text: 'สถานที่ปัจจุบัน: ยังไม่ได้เลือก'
        color: 0.2, 0.8, 0.2, 1
        size_hint_y: 0.1
        font_size: self.height * 0.5
        text_size: self.size
        halign: 'center'
        valign: 'middle'
        
    BoxLayout:
        size_hint_y: 0.1
        spacing: 10
        Label:
            text: 'สแกนสินค้า RFID:'
            font_size: self.height * 0.4
            size_hint_x: 0.3
        TextInput:
            id: inspect_inv_input
            multiline: False
            hint_text: 'สแกนป้ายสินค้า...'
            font_size: self.height * 0.4
            disabled: True # Disable until location is scanned
            on_text_validate: app.screens['main_tabs'].ids.inspection_tab.on_inventory_scanned(self.text)
            
    ScrollView:
        size_hint_y: 0.4
        BoxLayout:
            id: inspected_items_list
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            
    Label:
        id: inspection_result_label
        text: ''
        size_hint_y: 0.1
        font_size: self.height * 0.5
        color: 1, 1, 0, 1
        text_size: self.size
        halign: 'center'
        valign: 'middle'
            
    Button:
        text: 'ส่งผลการตรวจสอบ'
        size_hint_y: 0.1
        font_size: self.height * 0.4
        background_color: 0.2, 0.6, 1, 1
        on_release: app.screens['main_tabs'].ids.inspection_tab.submit_inspection()
